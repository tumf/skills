{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tumf.dev/skills/brainstorm-frameworks/schemas/ranking-output.schema.json",
  "title": "Ranking Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["top_candidates", "watchouts"],
  "properties": {
    "top_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["idea", "from_cluster", "score", "why", "key_assumptions"],
        "properties": {
          "idea": {"type": "string", "minLength": 1},
          "from_cluster": {"type": "string", "minLength": 1},
          "score": {
            "type": "object",
            "additionalProperties": false,
            "required": ["impact", "speed", "implementation_cost", "strategic_fit", "novelty", "confidence"],
            "properties": {
              "impact": {"type": "integer", "minimum": 1, "maximum": 5},
              "speed": {"type": "integer", "minimum": 1, "maximum": 5},
              "implementation_cost": {"type": "integer", "minimum": 1, "maximum": 5},
              "strategic_fit": {"type": "integer", "minimum": 1, "maximum": 5},
              "novelty": {"type": "integer", "minimum": 1, "maximum": 5},
              "confidence": {"type": "integer", "minimum": 1, "maximum": 5}
            }
          },
          "why": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          },
          "key_assumptions": {
            "type": "array",
            "items": {"type": "string"},
            "default": []
          }
        }
      }
    },
    "watchouts": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    }
  }
}
