{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tumf.dev/skills/brainstorm-frameworks/schemas/divergence-output.schema.json",
  "title": "Divergence Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["framework_used", "idea_groups", "observations"],
  "properties": {
    "framework_used": {"type": "string", "minLength": 1},
    "idea_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group", "ideas"],
        "properties": {
          "group": {"type": "string", "minLength": 1},
          "ideas": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "description", "rationale"],
              "properties": {
                "title": {"type": "string", "minLength": 1},
                "description": {"type": "string", "minLength": 1},
                "rationale": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "observations": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    }
  }
}
